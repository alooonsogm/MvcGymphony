@using System.Security.Claims
@model List<DatosSesion>
@{
    List<int> misReservas = ViewData["SESIONES_RESERVADAS"] as List<int> ?? new List<int>();
    string nombreUser = Context.User.FindFirst(ClaimTypes.Name).Value;
    string rolUser = Context.User.FindFirst(ClaimTypes.Role).Value;
    int idUsuarioActual = int.Parse(Context.User.FindFirst(ClaimTypes.NameIdentifier).Value);
}

<style>
    /* Cabecera de bienvenida */
    .home-header {
        margin-bottom: 3rem;
        animation: fadeInDown 0.6s ease-out;
    }

    .welcome-title {
        font-weight: 800;
        font-size: 2.2rem;
        color: #ffffff;
        letter-spacing: 1px;
    }

    .welcome-subtitle {
        color: var(--gymphony-light-blue);
        font-size: 1.1rem;
        font-weight: 500;
        margin: 0;
    }

    /* --- ALERTAS DE CRISTAL (Para mensajes de TempData) --- */
    .gymphony-alert {
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 12px;
        color: #fff;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        margin-top: 1.5rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.1);
        padding-right: 3rem;
    }

    .alert-success-glass {
        background: rgba(25, 135, 84, 0.25);
        border-left: 4px solid #20c997;
    }

    .alert-danger-glass {
        background: rgba(220, 53, 69, 0.25);
        border-left: 4px solid #ff6b6b;
    }

    .alert-info-glass {
        background: rgba(13, 202, 240, 0.20);
        border-left: 4px solid #0dcaf0;
    }

    .alert-warning-glass {
        background: rgba(253, 126, 20, 0.20);
        border-left: 4px solid #fd7e14;
    }

    .alert-icon {
        margin-right: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Tarjeta de Sesión (Efecto Cristal) */
    .sesion-card {
        background: rgba(10, 25, 49, 0.65);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(61, 165, 217, 0.2);
        border-radius: 16px;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        animation: fadeInUp 0.6s ease-out;
        position: relative;
    }

        .sesion-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(28, 89, 158, 0.4);
            border-color: rgba(61, 165, 217, 0.6);
        }

        /* Estilo especial si la clase es impartida por el entrenador logueado */
        .sesion-card.mi-clase {
            border-color: rgba(255, 193, 7, 0.6);
            box-shadow: 0 10px 25px rgba(255, 193, 7, 0.15);
        }

            .sesion-card.mi-clase:hover {
                border-color: #ffc107;
                box-shadow: 0 15px 30px rgba(255, 193, 7, 0.3);
            }

    .badge-mi-clase {
        position: absolute;
        top: -14px;
        left: 1.5rem;
        background: linear-gradient(135deg, #ffc107, #ff9800);
        color: #000;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        box-shadow: 0 4px 10px rgba(255, 193, 7, 0.4);
        z-index: 10;
        letter-spacing: 0.5px;
    }

    /* Parte superior de la tarjeta (Título y Hora) */
    .sesion-header {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        position: relative;
    }

    .sesion-title {
        color: #ffffff;
        font-weight: 800;
        font-size: 1.3rem;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .sesion-time-badge {
        background: rgba(61, 165, 217, 0.15);
        color: var(--gymphony-light-blue);
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.9rem;
        border: 1px solid rgba(61, 165, 217, 0.3);
        text-align: center;
        min-width: 80px;
    }

    /* Cuerpo de la tarjeta (Datos) */
    .sesion-body {
        padding: 1.5rem;
        flex-grow: 1;
    }

    .sesion-desc {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .sesion-info-row {
        display: flex;
        align-items: center;
        margin-bottom: 0.8rem;
        color: #e0e0e0;
        font-size: 0.95rem;
    }

    .sesion-info-icon {
        color: var(--gymphony-light-blue);
        margin-right: 12px;
        width: 20px;
        display: flex;
        justify-content: center;
    }

    /* Pie de la tarjeta (Botón) */
    .sesion-footer {
        padding: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-reservar {
        background: linear-gradient(135deg, var(--gymphony-blue), var(--gymphony-light-blue));
        border: none;
        color: white;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 0.8rem;
        border-radius: 10px;
        width: 100%;
        transition: all 0.3s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
    }

        .btn-reservar:hover {
            background: linear-gradient(135deg, var(--gymphony-light-blue), var(--gymphony-blue));
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(28, 89, 158, 0.5);
            color: white;
        }

    .btn-anular {
        background: rgba(220, 53, 69, 0.15);
        border: 1px solid rgba(220, 53, 69, 0.4);
        color: #ff6b6b;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 0.8rem;
        border-radius: 10px;
        width: 100%;
        transition: all 0.3s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
    }

        .btn-anular:hover {
            background: #dc3545;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(220, 53, 69, 0.4);
            color: white;
        }

    /* Estado Vacío */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: rgba(10, 25, 49, 0.4);
        border-radius: 20px;
        border: 1px dashed rgba(61, 165, 217, 0.3);
    }

    /* --- NUEVO: ESTILOS PERSONALIZADOS PARA SWEETALERT2 --- */

    /* El contenedor principal del popup */
    .swal-gymphony-popup {
        background: rgba(10, 25, 49, 0.85) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border: 1px solid rgba(61, 165, 217, 0.3) !important;
        border-radius: 20px !important;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5) !important;
        color: #ffffff !important;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important;
    }

    /* El título */
    .swal-gymphony-title {
        color: #ffffff !important;
        font-weight: 800 !important;
        letter-spacing: 1px !important;
        font-size: 1.8rem !important;
    }

    /* El texto descriptivo */
    .swal-gymphony-text {
        color: var(--text-muted) !important;
        font-size: 1.1rem !important;
    }

    /* Botón de confirmación (Genérico/Reserva) */
    .swal-btn-confirm {
        background: linear-gradient(135deg, var(--gymphony-blue), var(--gymphony-light-blue)) !important;
        border: none !important;
        border-radius: 10px !important;
        font-weight: 600 !important;
        letter-spacing: 1px !important;
        text-transform: uppercase !important;
        padding: 0.8rem 1.5rem !important;
        box-shadow: 0 8px 20px rgba(28, 89, 158, 0.4) !important;
    }

    /* Botón de confirmación para Anular (Rojo) */
    .swal-btn-confirm-danger {
        background: linear-gradient(135deg, #dc3545, #ff6b6b) !important;
        border: none !important;
        border-radius: 10px !important;
        font-weight: 600 !important;
        letter-spacing: 1px !important;
        text-transform: uppercase !important;
        padding: 0.8rem 1.5rem !important;
        box-shadow: 0 8px 20px rgba(220, 53, 69, 0.4) !important;
    }

    /* Botón de cancelar */
    .swal-btn-cancel {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: var(--text-muted) !important;
        border-radius: 10px !important;
        font-weight: 600 !important;
        letter-spacing: 1px !important;
        text-transform: uppercase !important;
        padding: 0.8rem 1.5rem !important;
    }

        .swal-btn-cancel:hover {
            background: rgba(255, 255, 255, 0.1) !important;
            color: #ffffff !important;
        }

    .btn-ver-socios {
        background: rgba(61, 165, 217, 0.1);
        border: 1px solid rgba(61, 165, 217, 0.4);
        color: var(--gymphony-light-blue);
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 0.8rem;
        border-radius: 10px;
        width: 100%;
        transition: all 0.3s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
    }

        .btn-ver-socios:hover {
            background: rgba(61, 165, 217, 0.25);
            color: #ffffff;
            box-shadow: 0 8px 20px rgba(61, 165, 217, 0.2);
        }
</style>

<div class="container mt-4">

    <div class="home-header">
        <h1 class="welcome-title">Hola, @nombreUser</h1>
        @if ( rolUser == "Socio" )
        {
            <p class="welcome-subtitle">Descubre y reserva tus próximas sesiones en Gymphony.</p>
        }
        else if ( rolUser == "Entrenador" )
        {
            <p class="welcome-subtitle">Gestiona tus clases y conecta con tus alumnos en Gymphony.</p>
        }
        else if ( rolUser == "Administrador" )
        {
            <p class="welcome-subtitle">Panel de control central: administra clases, entrenadores y socios activos en Gymphony.</p>
        }

        @if ( TempData["MENSAJERESERVA"] != null )
        {
            string mensaje = TempData["MENSAJERESERVA"].ToString();

            if ( mensaje == "Reserva realizada con éxito." )
            {
                <div class="alert alert-dismissible fade show gymphony-alert alert-success-glass" role="alert">
                    <div class="alert-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#20c997" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                        </svg>
                    </div>
                    <div>
                        <strong style="font-size: 1.1rem; display: block;">¡Reserva Confirmada!</strong>
                        <span style="color: #e9ecef; font-size: 0.95rem;">Tu plaza en @TempData["NOMBRECLASE"] ha sido asegurada con éxito. Te esperamos.</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            else if ( mensaje == "Reserva cancelada con éxito." )
            {
                <div class="alert alert-dismissible fade show gymphony-alert alert-info-glass" role="alert">
                    <div class="alert-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#0dcaf0" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                            <path d="M4 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 4 8z" />
                        </svg>
                    </div>
                    <div>
                        <strong style="font-size: 1.1rem; display: block;">Reserva Anulada</strong>
                        <span style="color: #e9ecef; font-size: 0.95rem;">Has cancelado tu plaza en @TempData["NOMBRECLASE"] correctamente. ¡Esperamos verte pronto!</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            else if ( mensaje == "Lo sentimos, la sesión está completa y no quedan plazas." )
            {
                <div class="alert alert-dismissible fade show gymphony-alert alert-warning-glass" role="alert">
                    <div class="alert-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#fd7e14" viewBox="0 0 16 16">
                            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                        </svg>
                    </div>
                    <div>
                        <strong style="font-size: 1.1rem; display: block;">Aforo Completo</strong>
                        <span style="color: #e9ecef; font-size: 0.95rem;">Lo sentimos, la sesión de @TempData["NOMBRECLASE"] está completa y no quedan plazas.</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            else
            {
                <div class="alert alert-dismissible fade show gymphony-alert alert-danger-glass" role="alert">
                    <div class="alert-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#ff6b6b" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z" />
                        </svg>
                    </div>
                    <div>
                        <strong style="font-size: 1.1rem; display: block;">Aviso</strong>
                        <span style="color: #e9ecef; font-size: 0.95rem;">@mensaje</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        }
    </div>

    <div class="row g-4">

        @if ( Model != null && Model.Any() )
        {
            @foreach ( DatosSesion sesion in Model )
            {
                <div class="col-12 col-md-6 col-xl-4" style="margin-top: 1.5rem;">
                    @{
                        bool esMiClase = (rolUser == "Entrenador") && (sesion.EntrenadorId == idUsuarioActual);
                        string claseCssMiClase = esMiClase ? "mi-clase" : "";
                    }

                    <div class="sesion-card @claseCssMiClase">
                        <div class="sesion-header">
                            @if ( esMiClase )
                            {
                                <div class="badge-mi-clase">
                                    ★ Tu Clase
                                </div>
                            }

                            <h3 class="sesion-title">@sesion.NombreClase</h3>
                            <div class="sesion-time-badge">
                                @sesion.HoraInicio.ToString("HH:mm") h <br />
                                <span style="font-size:0.75rem; color:#fff;">@sesion.HoraFin.ToString("HH:mm") h</span>
                            </div>
                        </div>

                        <div class="sesion-body">
                            <p class="sesion-desc" title="@sesion.Descripcion">
                                @sesion.Descripcion
                            </p>

                            <div class="sesion-info-row">
                                <div class="sesion-info-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
                                    </svg>
                                </div>
                                <span>@sesion.Fecha.ToString("dd/MM/yyyy")</span>
                            </div>

                            <div class="sesion-info-row">
                                <div class="sesion-info-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3Zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                                    </svg>
                                </div>
                                <span>@sesion.NombreEntrenador @sesion.ApellidoEntrenador</span>
                            </div>

                            <div class="sesion-info-row">
                                <div class="sesion-info-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z" />
                                    </svg>
                                </div>
                                <span>@sesion.NombreSala</span>
                            </div>

                            <div class="sesion-info-row mb-0">
                                <div class="sesion-info-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8Zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816ZM4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0Zm3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z" />
                                    </svg>
                                </div>
                                @{
                                    bool estaLlena = sesion.PlazasReservadas >= sesion.CapacidadMaxima;
                                    string colorTextoAforo = estaLlena ? "#ff6b6b" : "#e0e0e0";
                                }
                                <span style="color: @colorTextoAforo; font-weight: @(estaLlena ? "700" : "400");">
                                    Aforo: @sesion.PlazasReservadas / @sesion.CapacidadMaxima ocupadas
                                    @if ( estaLlena )
                                    {
                                        <span style="font-size: 0.8rem; margin-left: 5px;">(Completo)</span>
                                    }
                                </span>
                            </div>
                        </div>

                        @if ( rolUser == "Socio" )
                        {
                            <div class="sesion-footer">
                                @if ( misReservas.Contains(sesion.IdSesion) )
                                {
                                    <a href="javascript:void(0)" onclick="confirmarAnulacion('@Url.Action("AnularSesiones", "Home", new { idSesion = sesion.IdSesion })', '@sesion.NombreClase')" class="btn-anular">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                                            <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                                        </svg>
                                        Anular Reserva
                                    </a>
                                }
                                else
                                {
                                    <a href="javascript:void(0)" onclick="confirmarReserva('@Url.Action("ReservarSesiones", "Home", new { idSesion = sesion.IdSesion })', '@sesion.NombreClase')" class="btn-reservar">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                                            <path d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0z" />
                                        </svg>
                                        Reservar Plaza
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="sesion-footer">
                                <a href="javascript:void(0)" onclick="verSocios(@sesion.IdSesion, '@sesion.NombreClase')" class="btn-ver-socios">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                                        <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8Zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816ZM4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0Zm3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z" />
                                    </svg>
                                    Ver Socios Apuntados
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="var(--gymphony-light-blue)" class="mb-3" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                        <path d="M4.285 12.433a.5.5 0 0 0 .683-.183A3.498 3.498 0 0 1 8 10.5c1.295 0 2.426.703 3.032 1.75a.5.5 0 0 0 .866-.5A4.498 4.498 0 0 0 8 9.5a4.5 4.5 0 0 0-3.898 2.25.5.5 0 0 0 .183.683zM7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5zm4 0c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5z" />
                    </svg>
                    <h3 style="color: white; font-weight: 700;">No hay sesiones disponibles</h3>
                    <p style="color: var(--text-muted);">Actualmente no hay clases programadas. Vuelve a revisar más tarde.</p>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const customSwalClass = {
            popup: 'swal-gymphony-popup',
            title: 'swal-gymphony-title',
            htmlContainer: 'swal-gymphony-text',
            cancelButton: 'swal-btn-cancel'
        };

        function confirmarReserva(urlDestino, nombreClase) {
            Swal.fire({
                title: '¿Confirmar plaza?',
                html: `Estás a punto de reservar una plaza para <b>${nombreClase}</b>.`,
                icon: 'question',
                iconColor: '#3da5d9',
                showCancelButton: true,
                confirmButtonText: 'SÍ, RESERVAR',
                cancelButtonText: 'CANCELAR',
                buttonsStyling: false,
                customClass: {
                    ...customSwalClass,
                    confirmButton: 'swal-btn-confirm me-3',
                },
                backdrop: 'rgba(10, 25, 49, 0.7)'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = urlDestino;
                }
            });
        }

        function confirmarAnulacion(urlDestino, nombreClase) {
            Swal.fire({
                title: '¿Anular reserva?',
                html: `Vas a liberar tu plaza de <b>${nombreClase}</b>.<br><span style="font-size: 0.9em; opacity: 0.7;">Otro usuario podrá ocuparla.</span>`,
                icon: 'warning',
                iconColor: '#ff6b6b',
                showCancelButton: true,
                confirmButtonText: 'SÍ, ANULAR PLAZA',
                cancelButtonText: 'MANTENER',
                buttonsStyling: false,
                customClass: {
                    ...customSwalClass,
                    confirmButton: 'swal-btn-confirm-danger me-3',
                },
                backdrop: 'rgba(10, 25, 49, 0.7)'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = urlDestino;
                }
            });
        }

        function verSocios(idSesion, nombreClase) {
            Swal.fire({
                title: 'Buscando asistentes...',
                html: 'Conectando con la base de datos.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading() },
                customClass: customSwalClass,
                backdrop: 'rgba(10, 25, 49, 0.7)'
            });

            fetch(`/Home/GetSociosSesion?idSesion=${idSesion}`)
                .then(response => response.json())
                .then(data => {
                    if (data.length === 0) {
                        Swal.fire({
                            title: 'Lista vacía',
                            html: `Todavía no hay nadie apuntado a <b>${nombreClase}</b>.`,
                            icon: 'info',
                            iconColor: '#3da5d9',
                            confirmButtonText: 'CERRAR',
                            buttonsStyling: false,
                            customClass: {
                                ...customSwalClass,
                                confirmButton: 'swal-btn-cancel'
                            },
                            backdrop: 'rgba(10, 25, 49, 0.7)'
                        });
                        return;
                    }

                    let htmlList = '<div style="max-height: 300px; overflow-y: auto; text-align: left; margin-top: 15px;">';

                    data.forEach((socio, index) => {
                        htmlList += `
                            <div style="display: flex; align-items: center; padding: 12px 10px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <div style="width: 35px; height: 35px; border-radius: 50%; background: linear-gradient(135deg, #1c599e, #3da5d9); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; margin-right: 15px; flex-shrink: 0;">
                                    ${index + 1}
                                </div>
                                <div>
                                    <div style="font-weight: 600; color: #fff; font-size: 1.05rem;">${socio.nombreCompleto}</div>
                                    <div style="font-size: 0.85rem; color: #adb5bd;">${socio.email}</div>
                                </div>
                            </div>
                        `;
                    });
                    htmlList += '</div>';

                    Swal.fire({
                        title: `Asistentes: ${nombreClase}`,
                        html: htmlList,
                        confirmButtonText: 'CERRAR',
                        buttonsStyling: false,
                        customClass: {
                            ...customSwalClass,
                            confirmButton: 'swal-btn-cancel'
                        },
                        backdrop: 'rgba(10, 25, 49, 0.7)'
                    });
                })
                .catch(error => {
                    Swal.fire({
                        title: 'Error',
                        text: 'Hubo un problema al cargar los asistentes.',
                        icon: 'error',
                        customClass: customSwalClass,
                        backdrop: 'rgba(10, 25, 49, 0.7)'
                    });
                });
        }
    </script>
}