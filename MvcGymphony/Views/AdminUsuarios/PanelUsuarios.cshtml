@model AdminGestionUsuarios
@{
    string seccionActiva = ViewData["SECCIONACTIVA"].ToString();
}

<style>
    /* Cabecera del Panel */
    .admin-header {
        margin-bottom: 2rem;
    }

    .admin-title {
        font-weight: 800;
        font-size: 2.2rem;
        color: #ffffff;
        letter-spacing: 1px;
    }

    /* Menú de Navegación */
    .admin-tabs-container {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid rgba(61, 165, 217, 0.2);
        padding-bottom: 1rem;
    }

    .admin-tab-btn {
        background: rgba(10, 25, 49, 0.4);
        border: 1px solid rgba(61, 165, 217, 0.3);
        color: var(--text-muted);
        padding: 0.8rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }

        .admin-tab-btn:hover {
            background: rgba(61, 165, 217, 0.15);
            color: #fff;
        }

        .admin-tab-btn.active {
            background: linear-gradient(135deg, var(--gymphony-blue), var(--gymphony-light-blue));
            color: white;
            border-color: transparent;
            box-shadow: 0 8px 20px rgba(28, 89, 158, 0.4);
        }

    /* Contenedor Cristal */
    .glass-table-wrapper {
        background: rgba(10, 25, 49, 0.65);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(61, 165, 217, 0.25);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        padding: 2rem;
        overflow-x: auto;
    }

    .glass-table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .glass-table-title {
        color: var(--gymphony-light-blue);
        font-size: 1.4rem;
        font-weight: 800;
        margin: 0;
        text-transform: uppercase;
    }

    /* Botón Crear */
    .btn-create-new {
        background: rgba(32, 201, 151, 0.15);
        border: 1px solid #20c997;
        color: #20c997;
        padding: 0.6rem 1.4rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        letter-spacing: 0.5px;
    }

        .btn-create-new:hover {
            background: #20c997;
            color: #000;
            box-shadow: 0 5px 15px rgba(32, 201, 151, 0.3);
        }

    /* Tabla */
    .gymphony-table {
        width: 100%;
        border-collapse: collapse;
        color: #fff;
    }

        .gymphony-table th {
            border-bottom: 2px solid var(--gymphony-light-blue);
            padding: 1.2rem 1rem;
            text-align: left;
            color: var(--gymphony-light-blue);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
        }

        .gymphony-table td {
            padding: 1.2rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            vertical-align: middle;
            font-size: 1rem;
        }

        .gymphony-table tr:hover td {
            background-color: rgba(255, 255, 255, 0.02);
        }

    /* Botones Acción */
    .action-btn {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        margin-left: 0.5rem;
        transition: all 0.2s;
        display: inline-block;
    }

    .action-edit {
        background: rgba(253, 126, 20, 0.15);
        color: #fd7e14;
        border: 1px solid rgba(253, 126, 20, 0.3);
    }

        .action-edit:hover {
            background: #fd7e14;
            color: #fff;
        }

    .action-delete {
        background: rgba(220, 53, 69, 0.15);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
    }

        .action-delete:hover {
            background: #dc3545;
            color: #fff;
        }

    /* Nueva clase para el botón verde de Dar Alta */
    .action-success {
        background: rgba(32, 201, 151, 0.15);
        color: #20c997;
        border: 1px solid rgba(32, 201, 151, 0.3);
    }

        .action-success:hover {
            background: #20c997;
            color: #000; /* O #fff si prefieres el texto blanco al iluminarse */
        }

    /* Nueva clase para el botón azul de Horarios */
    .action-info {
        background: rgba(61, 165, 217, 0.15);
        color: var(--gymphony-light-blue);
        border: 1px solid rgba(61, 165, 217, 0.3);
    }

        .action-info:hover {
            background: var(--gymphony-light-blue);
            color: #000;
        }

    /* SweetAlert Custom Styles */
    .swal-gymphony-popup {
        background: rgba(10, 25, 49, 0.95) !important;
        backdrop-filter: blur(20px) !important;
        border: 1px solid rgba(61, 165, 217, 0.3) !important;
        border-radius: 16px !important;
        color: #ffffff !important;
    }

    .swal-gymphony-title {
        color: #ffffff !important;
        font-weight: 800 !important;
        font-size: 1.6rem !important;
    }

    .swal-btn-save {
        background: linear-gradient(135deg, #20c997, #17a589) !important;
        border: none !important;
        color: #000 !important;
        font-weight: 700 !important;
        border-radius: 8px !important;
        padding: 0.7rem 1.8rem !important;
        box-shadow: 0 5px 15px rgba(32, 201, 151, 0.4) !important;
    }

    .swal-btn-edit {
        background: linear-gradient(135deg, #fd7e14, #e8590c) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 700 !important;
        border-radius: 8px !important;
        padding: 0.7rem 1.8rem !important;
        box-shadow: 0 5px 15px rgba(253, 126, 20, 0.4) !important;
    }

    .swal-btn-danger {
        background: linear-gradient(135deg, #dc3545, #ff6b6b) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 700 !important;
        border-radius: 8px !important;
        padding: 0.7rem 1.8rem !important;
        box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4) !important;
    }

    .swal-btn-cancel {
        background: transparent !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        color: var(--text-muted) !important;
        border-radius: 8px !important;
        font-weight: 600 !important;
        padding: 0.7rem 1.5rem !important;
        transition: all 0.3s ease !important; /* Añadimos la transición suave */
    }

        /* NUEVO: El efecto hover para el botón de cancelar */
        .swal-btn-cancel:hover {
            background: rgba(255, 255, 255, 0.1) !important; /* Fondo ligeramente blanco */
            color: #ffffff !important; /* El texto se vuelve blanco brillante */
            border-color: rgba(255, 255, 255, 0.4) !important; /* El borde resalta más */
        }

    .swal-gymphony-input {
        background: rgba(0, 0, 0, 0.3) !important;
        border: 1px solid rgba(61, 165, 217, 0.3) !important;
        color: #ffffff !important;
        border-radius: 8px !important;
        padding: 12px 15px !important;
        width: 100% !important;
        margin-bottom: 15px !important;
        box-sizing: border-box !important;
        transition: all 0.3s ease !important;
    }

        .swal-gymphony-input:focus {
            outline: none !important;
            border-color: var(--gymphony-light-blue) !important;
            box-shadow: 0 0 10px rgba(61, 165, 217, 0.4) !important;
            background: rgba(0, 0, 0, 0.5) !important;
        }

    .swal-modal-label {
        color: var(--gymphony-light-blue);
        font-size: 0.85rem;
        font-weight: bold;
        text-transform: uppercase;
        margin-bottom: 5px;
        display: block;
    }
</style>

<div class="container mt-4 pb-5">

    <div class="admin-header">
        <h1 class="admin-title">Gestión de Usuarios</h1>
        <p style="color: var(--text-muted); font-size: 1.1rem;">Panel de administración para la gestión de socios y plantilla de entrenadores.</p>
    </div>

    <div class="admin-tabs-container">
        <a asp-controller="AdminUsuarios" asp-action="PanelUsuarios" asp-route-seccion="socios" class="admin-tab-btn @(seccionActiva == "socios" ? "active" : "")">
            Socios
        </a>
        <a asp-controller="AdminUsuarios" asp-action="PanelUsuarios" asp-route-seccion="entrenadores" class="admin-tab-btn @(seccionActiva == "entrenadores" ? "active" : "")">
            Entrenadores
        </a>
    </div>

    <div class="glass-table-wrapper">

        @if ( seccionActiva == "socios" )
        {
            <div class="glass-table-header">
                <h2 class="glass-table-title">Socios Afiliados</h2>
                <a asp-controller="AdminUsuarios" asp-action="CrearSocio" class="btn-create-new">+ Crear Socio</a>
            </div>

            <table class="gymphony-table">
                <thead>
                    <tr>
                        <th>Nombre Completo</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Fecha de Nacimiento</th>
                        <th>DNI</th>
                        <th style="text-align: right; width: 230px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach ( VistaSocio socio in Model.Socios )
                    {
                        <tr>
                            <td style="font-weight: 600;">
                                <div style="display: flex; align-items: center;">
                                    <div style="width: 30px; height: 30px; border-radius: 50%; background: var(--gymphony-light-blue); color: #000; display: flex; justify-content: center; align-items: center; font-weight: bold; margin-right: 10px; font-size: 0.8rem;">
                                        @socio.Nombre.Substring(0, 1)@socio.Apellidos.Substring(0, 1)
                                    </div>
                                    @socio.Nombre @socio.Apellidos
                                </div>
                            </td>
                            <td style="color: var(--text-muted);">@socio.Email</td>
                            <td>@socio.Telefono</td>
                            <td>@socio.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                            <td><span style="background: rgba(255,255,255,0.05); padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">@socio.DNI</span></td>
                            <td style="text-align: right; white-space: nowrap;">
                                @if ( socio.esActivo )
                                {
                                    <a href="javascript:void(0)" onclick="darDeBajaSocio(@socio.IdSocio, '@socio.Nombre @socio.Apellidos')" class="action-btn action-edit">⬇ Dar Baja</a>
                                }
                                else
                                {
                                    <a href="javascript:void(0)" onclick="DarDeAltaSocio(@socio.IdSocio, '@socio.Nombre @socio.Apellidos')" class="action-btn action-success">⬆ Dar Alta</a>
                                }

                                <a href="javascript:void(0)" onclick="borrarSocioDefinitivo(@socio.IdSocio, '@socio.Nombre')" class="action-btn action-delete">Borrar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        else if ( seccionActiva == "entrenadores" )
        {
            <div class="glass-table-header">
                <h2 class="glass-table-title">Plantilla de Entrenadores</h2>
                <a asp-controller="AdminUsuarios" asp-action="CrearEntrenador" class="btn-create-new">+ Crear Entrenador</a>
            </div>

            <table class="gymphony-table">
                <thead>
                    <tr>
                        <th>Nombre Completo</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Fecha Nacimiento</th>
                        <th>DNI</th>
                        <th style="text-align: right; width: 250px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach ( VistaUsuario entrenador in Model.Entrenadores )
                    {
                        <tr>
                            <td style="font-weight: 600;">
                                <div style="display: flex; align-items: center;">
                                    <div style="width: 30px; height: 30px; border-radius: 50%; background: var(--gymphony-light-blue); color: #000; display: flex; justify-content: center; align-items: center; font-weight: bold; margin-right: 10px; font-size: 0.8rem;">
                                        @entrenador.Nombre.Substring(0, 1)@entrenador.Apellidos.Substring(0, 1)
                                    </div>
                                    @entrenador.Nombre @entrenador.Apellidos
                                </div>
                            </td>
                            <td style="color: var(--text-muted);">@entrenador.Email</td>
                            <td>@entrenador.Telefono</td>
                            <td>@entrenador.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                            <td><span style="background: rgba(255,255,255,0.05); padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">@entrenador.Dni</span></td>
                            <td style="text-align: right; white-space: nowrap;">
                                <a href="javascript:void(0)" onclick="verHorarios(@entrenador.IdUsuario, '@entrenador.Nombre @entrenador.Apellidos')" class="action-btn action-info">Horarios</a>
                                <a href="javascript:void(0)" onclick="borrarEntrenador(@entrenador.IdUsuario, '@entrenador.Nombre @entrenador.Apellidos')" class="action-btn action-delete">Borrar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

    </div>
</div>

@section Scripts {
    <script>
        const customSwalClass = {
            popup: 'swal-gymphony-popup',
            title: 'swal-gymphony-title',
            htmlContainer: 'swal-gymphony-text',
            cancelButton: 'swal-btn-cancel'
        };

        @if ( TempData["MENSAJE_EXITO"] != null )
        {
                    <text>
                    document.addEventListener("DOMContentLoaded", function() {
                        Swal.fire({
                            title: '¡Alta Completada!',
                                    text: '@Html.Raw(TempData["MENSAJE_EXITO"])',
                            icon: 'success',
                            iconColor: '#20c997',
                            customClass: customSwalClass,
                            backdrop: 'rgba(10, 25, 49, 0.8)',
                            confirmButtonText: 'Genial',
                            buttonsStyling: false,
                            customClass: {
                                ...customSwalClass,
                                confirmButton: 'swal-btn-save'
                            }
                        });
                    });
                    </text>
        }

        function borrarSocioDefinitivo(idSocio, nombre) {
            Swal.fire({
                title: '¿BORRADO DEFINITIVO?',
                html: `Estás a punto de aplicar un borrado permanente a <b>${nombre}</b>.<br><br>
                       <div style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.3); padding: 15px; border-radius: 8px; text-align: left;">
                           <span style="color: #ff6b6b; font-weight: bold; display: block; margin-bottom: 5px;">Se eliminará:</span>
                           <ul style="color: #ff6b6b; font-size: 0.9em; margin-bottom: 0; padding-left: 20px;">
                               <li>Sus datos personales y credenciales.</li>
                               <li>Su historial de altas y bajas.</li>
                               <li>Todas sus reservas de sesiones.</li>
                               <li>Su registro de accesos al centro.</li>
                           </ul>
                       </div>`,
                icon: 'warning',
                iconColor: '#ff6b6b',
                showCancelButton: true,
                confirmButtonText: 'SÍ, BORRAR TODO',
                cancelButtonText: 'CANCELAR',
                buttonsStyling: false,
                customClass: {
                    ...customSwalClass,
                    confirmButton: 'swal-btn-danger me-3',
                },
                backdrop: 'rgba(10, 25, 49, 0.8)'
            }).then((result) => {
                if (result.isConfirmed) {

                    Swal.fire({
                        title: 'Eliminando datos...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading() },
                        customClass: customSwalClass,
                        backdrop: 'rgba(10, 25, 49, 0.8)'
                    });

                    fetch(`/AdminUsuarios/EliminarSocio?id=${idSocio}`, {
                        method: 'POST'
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: '¡Borrado Completado!',
                                text: `El expediente de ${nombre} ha sido destruido.`,
                                icon: 'success',
                                iconColor: '#20c997',
                                customClass: customSwalClass,
                                backdrop: 'rgba(10, 25, 49, 0.8)'
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                title: 'Error',
                                text: data.message,
                                icon: 'error',
                                customClass: customSwalClass,
                                backdrop: 'rgba(10, 25, 49, 0.8)'
                            });
                        }
                    })
                    .catch(error => {
                        Swal.fire('Error', 'Hubo un problema de conexión con el servidor.', 'error');
                    });
                }
            });
        }

        function darDeBajaSocio(idSocio, nombre) {
            Swal.fire({
                title: '¿Dar de Baja?',
                html: `Vas a tramitar la baja de <b>${nombre}</b>.<br><br>
                       <span style="font-size: 0.9em; opacity: 0.8;">Su historial y datos se conservarán, pero pasará a estar Inactivo y se registrará la fecha de hoy como fin de su suscripción.</span>`,
                icon: 'warning',
                iconColor: '#fd7e14',
                showCancelButton: true,
                confirmButtonText: 'SÍ, TRAMITAR BAJA',
                cancelButtonText: 'CANCELAR',
                buttonsStyling: false,
                customClass: {
                    ...customSwalClass,
                    confirmButton: 'swal-btn-edit me-3'
                },
                backdrop: 'rgba(10, 25, 49, 0.8)'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Procesando...', didOpen: () => { Swal.showLoading() }, customClass: customSwalClass, backdrop: 'rgba(10, 25, 49, 0.8)' });

                    fetch(`/AdminUsuarios/DarBajaSocio?id=${idSocio}`, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: '¡Baja Tramitada!',
                                text: `${nombre} ahora consta como inactivo.`,
                                icon: 'success',
                                iconColor: '#fd7e14',
                                customClass: customSwalClass,
                                backdrop: 'rgba(10, 25, 49, 0.8)'
                            }).then(() => { window.location.reload(); });
                        } else {
                            Swal.fire('Error', data.message, 'error');
                        }
                    });
                }
            });
        }

        function DarDeAltaSocio(idSocio, nombre) {
            Swal.fire({
                title: '¿Reactivar Membresía?',
                html: `Vas a dar de alta nuevamente a <b>${nombre}</b>.<br><br>
                       <span style="font-size: 0.9em; opacity: 0.8;">Pasará a estar Activo y se registrará la fecha de hoy como inicio de su suscripción.</span>`,
                icon: 'question',
                iconColor: '#20c997',
                showCancelButton: true,
                confirmButtonText: 'SÍ, DAR DE ALTA',
                cancelButtonText: 'CANCELAR',
                buttonsStyling: false,
                customClass: {
                    ...customSwalClass,
                    confirmButton: 'swal-btn-save me-3'
                },
                backdrop: 'rgba(10, 25, 49, 0.8)'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Procesando...', didOpen: () => { Swal.showLoading() }, customClass: customSwalClass, backdrop: 'rgba(10, 25, 49, 0.8)' });

                    fetch(`/AdminUsuarios/DarDeAltaSocio?id=${idSocio}`, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: '¡Socio Reactivado!',
                                text: `${nombre} vuelve a estar activo en el gimnasio.`,
                                icon: 'success',
                                iconColor: '#20c997',
                                customClass: customSwalClass,
                                backdrop: 'rgba(10, 25, 49, 0.8)'
                            }).then(() => { window.location.reload(); });
                        } else {
                            Swal.fire('Error', data.message, 'error');
                        }
                    });
                }
            });
        }

        function verHorarios(idEntrenador, nombre) {
            const nombresDias = ["", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"];

            Swal.fire({
                title: `Horarios de ${nombre}`,
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading() },
                customClass: customSwalClass,
                backdrop: 'rgba(10, 25, 49, 0.8)'
            });

            fetch(`/AdminUsuarios/ObtenerHorariosEntrenador?id=${idEntrenador}`, { method: 'POST' })
                .then(response => response.json())
                .then(resultado => {
                    if (resultado.success) {
                        if (resultado.data.length === 0) {
                            Swal.fire({
                                title: `Horarios de ${nombre}`,
                                html: `<p style="color: var(--text-muted);">Este entrenador no tiene turnos asignados actualmente.</p>`,
                                icon: 'info',
                                customClass: customSwalClass,
                                confirmButtonText: 'Cerrar',
                                buttonsStyling: false,
                                customClass: { ...customSwalClass, confirmButton: 'swal-btn-cancel' },
                                backdrop: 'rgba(10, 25, 49, 0.8)'
                            });
                            return;
                        }

                        let tablaHtml = `
                            <table class="gymphony-table" style="font-size: 0.9rem; text-align: left; margin-top: 15px;">
                                <thead>
                                    <tr>
                                        <th style="padding: 10px; border-bottom: 1px solid rgba(61, 165, 217, 0.3);">Día</th>
                                        <th style="padding: 10px; border-bottom: 1px solid rgba(61, 165, 217, 0.3);">Inicio</th>
                                        <th style="padding: 10px; border-bottom: 1px solid rgba(61, 165, 217, 0.3);">Fin</th>
                                    </tr>
                                </thead>
                                <tbody>
                        `;

                        resultado.data.forEach(turno => {
                            tablaHtml += `
                                <tr>
                                    <td style="padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); font-weight: bold; color: var(--gymphony-light-blue);">${nombresDias[turno.diaSemana]}</td>
                                    <td style="padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.05);">${turno.horaInicio}</td>
                                    <td style="padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.05);">${turno.horaFin}</td>
                                </tr>
                            `;
                        });

                        tablaHtml += `</tbody></table>`;

                        Swal.fire({
                            title: `Horarios de ${nombre}`,
                            html: tablaHtml,
                            customClass: customSwalClass,
                            confirmButtonText: 'Cerrar',
                            buttonsStyling: false,
                            customClass: { ...customSwalClass, confirmButton: 'swal-btn-cancel' },
                            backdrop: 'rgba(10, 25, 49, 0.8)'
                        });

                    } else {
                        Swal.fire('Error', resultado.message, 'error');
                    }
                })
                .catch(error => {
                    Swal.fire('Error', 'No se pudieron cargar los horarios.', 'error');
                });
        }

        function borrarEntrenador(idEntrenador, nombre) {
            Swal.fire({ title: 'Comprobando datos...', didOpen: () => { Swal.showLoading() }, customClass: customSwalClass, backdrop: 'rgba(10, 25, 49, 0.8)' });

            fetch(`/AdminUsuarios/ValidarBorradoEntrenador?id=${idEntrenador}`)
            .then(res => res.json())
            .then(data => {
                if (!data.success) {
                    Swal.fire('Error', data.message, 'error');
                    return;
                }

                if (data.hasSessions) {
                    if (data.sustitutos.length === 0) {
                        Swal.fire({
                            title: 'Operación Bloqueada',
                            text: 'Este entrenador tiene sesiones asignadas, pero no hay ningún otro entrenador en la plantilla para sustituirlo. Debes contratar a otro entrenador primero.',
                            icon: 'error',
                            customClass: customSwalClass,
                            backdrop: 'rgba(10, 25, 49, 0.8)'
                        });
                        return;
                    }

                    let options = '<option value="">-- Selecciona un sustituto --</option>';
                    data.sustitutos.forEach(s => {
                        options += `<option value="${s.id}">${s.nombre}</option>`;
                    });

                    Swal.fire({
                        title: '¡Atención! Entrenador con sesiones',
                        html: `<b>${nombre}</b> tiene sesiones asignadas.<br><br>
                               <span style="font-size:0.9em; color:var(--text-muted);">Para no perder el historial del gimnasio, debes reasignar sus clases a otro entrenador antes de borrarlo.</span><br><br>
                               <select id="swal-sustituto" class="swal-gymphony-input" style="width: 100%; margin-top: 10px;">
                                   ${options}
                               </select>`,
                        icon: 'warning',
                        iconColor: '#fd7e14',
                        showCancelButton: true,
                        confirmButtonText: 'REASIGNAR Y BORRAR',
                        cancelButtonText: 'CANCELAR',
                        buttonsStyling: false,
                        customClass: { ...customSwalClass, confirmButton: 'swal-btn-danger me-3' },
                        backdrop: 'rgba(10, 25, 49, 0.8)',
                        preConfirm: () => {
                            const sustitutoId = document.getElementById('swal-sustituto').value;
                            if (!sustitutoId) {
                                Swal.showValidationMessage('Debes seleccionar un entrenador sustituto');
                            }
                            return sustitutoId;
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            ejecutarBorrado(idEntrenador, result.value, nombre);
                        }
                    });

                }
                else {
                    Swal.fire({
                        title: '¿Borrar Entrenador?',
                        html: `Estás a punto de borrar a <b>${nombre}</b>.<br><br>
                               <span style="color:#ff6b6b; font-size:0.9em;">No tiene sesiones asignadas. Su usuario y turnos de trabajo se eliminarán de forma permanente.</span>`,
                        icon: 'warning',
                        iconColor: '#ff6b6b',
                        showCancelButton: true,
                        confirmButtonText: 'SÍ, BORRAR DEFINITIVO',
                        cancelButtonText: 'CANCELAR',
                        buttonsStyling: false,
                        customClass: { ...customSwalClass, confirmButton: 'swal-btn-danger me-3' },
                        backdrop: 'rgba(10, 25, 49, 0.8)'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            ejecutarBorrado(idEntrenador, null, nombre);
                        }
                    });
                }
            });
        }

        function ejecutarBorrado(idBorrar, idSustituto, nombre) {
            Swal.fire({ title: 'Procesando...', didOpen: () => { Swal.showLoading() }, customClass: customSwalClass, backdrop: 'rgba(10, 25, 49, 0.8)' });

            let url = `/AdminUsuarios/EliminarEntrenador?idBorrar=${idBorrar}`;
            if (idSustituto) {
                url += `&idSustituto=${idSustituto}`;
            }

            fetch(url, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: '¡Entrenador Borrado!',
                        text: `El usuario ${nombre} ha sido eliminado con éxito de la plantilla.`,
                        icon: 'success',
                        iconColor: '#20c997',
                        customClass: customSwalClass,
                        backdrop: 'rgba(10, 25, 49, 0.8)'
                    }).then(() => window.location.reload());
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            });
        }
    </script>
}